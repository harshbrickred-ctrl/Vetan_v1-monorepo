{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && npm run db:migrate && npm run build -- --filter=@sangam/web",
  "installCommand": "cd ../.. && npm install --workspaces --include-workspace-root",
  "framework": "nextjs",
  "regions": ["bom1"],
  "functions": {
    "src/app/v1/payroll/runs/[id]/finalize/route.ts": {
      "maxDuration": 300
    },
    "src/app/v1/payroll/runs/[id]/preview/route.ts": {
      "maxDuration": 120
    },
    "src/app/v1/payroll/runs/[id]/validate/route.ts": {
      "maxDuration": 60
    },
    "src/app/v1/reports/run/route.ts": {
      "maxDuration": 120
    },
    "src/app/v1/employees/export/route.ts": {
      "maxDuration": 60
    },
    "src/app/v1/platform/tenants/route.ts": {
      "maxDuration": 60
    },
    "src/app/v1/_cron/seed-attendance/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/v1/_cron/seed-attendance",
      "schedule": "0 3 * * *"
    }
  ]
}
