// Sangam — core schema (formerly Vetan; merged monorepo on Next.js + Neon)

generator client {
  provider        = "prisma-client-js"
  // Emit into the workspace package so any app in the monorepo can import
  // `@prisma/client` and pick up the generated types via @sangam/db.
  previewFeatures = []
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (Neon's PgBouncer endpoint) — used at runtime.
  url       = env("DATABASE_URL")
  // Direct connection — used only by `prisma migrate` / `prisma db push`.
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  NOTICE
  INACTIVE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACTOR
  INTERN
}

enum LifecycleStage {
  PROBATION
  CONFIRMED
  NOTICE_PERIOD
  EXITED
}

enum SalaryComponentType {
  FIXED
  VARIABLE
  STATUTORY
  REIMBURSABLE
}

enum PayrollRunStatus {
  DRAFT
  PROCESSING
  PENDING
  APPROVED
  LOCKED
  DISBURSED
  ERROR
}

/// How salary is transferred to the employee bank account
enum SalaryPaymentMethod {
  NEFT
  RTGS
  IMPS
  CHEQUE
  CASH
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum TaskStatus {
  PENDING
  ACCEPTED
  WORKING
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

/** Platform-owner view: whether the tenant paid their Vetan subscription this cycle */
enum TenantPaymentStatus {
  PAID
  UNPAID
  OVERDUE
  WAIVED
}

/** Organization legal / compliance documents stored per tenant */
enum TenantLegalDocumentType {
  CERTIFICATE_OF_INCORPORATION
  MEMORANDUM_ARTICLES
  GST_REGISTRATION
  PAN_ENTITY
  SHOPS_AND_ESTABLISHMENTS
  MSME_UDYAM
  LABOUR_LICENSE
  OTHER
}

/** KYC / onboarding files kept per employee (uploaded by HR during onboarding) */
enum EmployeeOnboardingDocumentType {
  PAN_CARD
  AADHAAR
  ADDRESS_PROOF
  BANK_PROOF
  PHOTOGRAPH
  OFFER_LETTER
  EXPERIENCE_CERTIFICATE
  EDUCATION_CERTIFICATE
  OTHER
}

// ─── Platform (SaaS owner) ───────────────────────

model PlatformAdmin {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String
  name            String
  status          UserStatus @default(ACTIVE)
  lastLoginAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

/** Default holidays applied to every tenant unless overridden on that date. */
model PlatformHoliday {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date])
  @@index([date])
}

// ─── Tenant & identity ─────────────────────────────

model Tenant {
  id                     String    @id @default(uuid())
  slug                   String    @unique
  /** Short unique org code (e.g. BR, AC) used in employee login usernames */
  companyCode            String?   @unique
  name                   String
  legalName              String?
  industry               String?
  country                String    @default("IN")
  /** Workspace-scoped settings (company profile, statutory, payroll prefs, etc.) */
  settings               Json      @default("{}")
  onboardingCompletedAt  DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  users                  User[]
  roles                  Role[]
  departments            Department[]
  designations           Designation[]
  holidays               TenantHoliday[]
  employees              Employee[]
  salaryComponents       SalaryComponent[]
  salaryStructures       SalaryStructure[]
  leaveTypes             LeaveType[]
  payrollRuns            PayrollRun[]
  leaveRequests          LeaveRequest[]
  attendanceRecords      AttendanceRecord[]
  tasks                  Task[]
  visitorRecords         VisitorRecord[]
  payGroups              PayGroup[]
  legalEntities          LegalEntity[]
  policyDocuments        PolicyDocument[]
  shifts                 Shift[]
  reimbursementClaims    ReimbursementClaim[]
  employeeLoans          EmployeeLoan[]
  announcements          Announcement[]
  supportTickets         SupportTicket[]
  recognitions           Recognition[]
  trainingCourses        TrainingCourse[]
  assets                 Asset[]
  auditLogs              AuditLog[]
  notifications          Notification[]
  subscriptions          Subscription[]
  billingOps             TenantBillingOps?
  legalDocuments         TenantLegalDocument[]
  employeeOnboardingDocuments EmployeeOnboardingDocument[]
}

model TenantLegalDocument {
  id                String                  @id @default(uuid())
  tenantId          String
  tenant            Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documentType      TenantLegalDocumentType
  originalFilename  String
  storedFilename    String
  mimeType          String
  sizeBytes         Int
  createdAt         DateTime                @default(now())

  @@index([tenantId])
}

model User {
  id                String     @id @default(uuid())
  tenantId          String
  tenant            Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email             String
  /** Employee portal login id: companyCode + employeeCode (admins use email) */
  loginUsername     String?
  passwordHash      String
  name              String
  phone             String?
  phoneAlt          String?
  aadhar            String?
  pan               String?
  status            UserStatus @default(ACTIVE)
  emailVerifiedAt   DateTime?
  failedLoginCount  Int        @default(0)
  lockedUntil       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  roles             UserRole[]
  refreshTokens     RefreshToken[]
  employee          Employee?
  assignedTasks     Task[]     @relation("TaskAssignedBy")

  @@unique([tenantId, email])
  @@unique([tenantId, loginUsername])
  @@index([tenantId, id])
}

model Permission {
  id          String           @id @default(uuid())
  code        String           @unique
  description String?
  rolePerms   RolePermission[]
}

model Role {
  id          String             @id @default(uuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  permissions RolePermission[]
  users       UserRole[]

  @@unique([tenantId, name])
  @@index([tenantId, id])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailVerificationOtp {
  id        String   @id @default(uuid())
  email     String
  tenantId  String?
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// ─── Organization ──────────────────────────────────

model Department {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  code        String
  headUserId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  employees   Employee[]
  designations Designation[]

  @@unique([tenantId, code])
  @@index([tenantId, id])
}

model Designation {
  id           String     @id @default(uuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  title        String
  grade        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  employees    Employee[]

  @@index([tenantId, id])
}

model TenantHoliday {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, date])
  @@index([tenantId, date])
}

model Employee {
  id             String            @id @default(uuid())
  tenantId       String
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String?           @unique
  user           User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  employeeCode   String
  firstName      String
  lastName       String
  email          String
  departmentId   String?
  department     Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designationId  String?
  designation    Designation?      @relation(fields: [designationId], references: [id], onDelete: SetNull)
  managerId      String?
  manager        Employee?         @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports  Employee[]        @relation("EmployeeManager")
  legalEntityId  String?
  legalEntity    LegalEntity?      @relation(fields: [legalEntityId], references: [id], onDelete: SetNull)
  employmentType EmploymentType    @default(FULL_TIME)
  lifecycleStage LifecycleStage?
  probationEndDate DateTime?       @db.Date
  exitDate       DateTime?         @db.Date
  status         EmploymentStatus  @default(ACTIVE)
  dateOfJoining  DateTime
  ctcAnnual      Decimal?          @db.Decimal(14, 2)
  pan            String?
  bankName       String?
  bankAccount    String?
  ifsc           String?
  salaryPaymentMethod SalaryPaymentMethod @default(NEFT)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  version        Int               @default(0)

  salaryAssignments SalaryAssignment[]
  attendanceRecords AttendanceRecord[]
  leaveBalances     LeaveBalance[]
  leaveRequests     LeaveRequest[]
  assignedTasks     Task[]
  visitorsToMeet    VisitorRecord[] @relation("VisitorHost")
  visitorsRegistered VisitorRecord[] @relation("VisitorRegisteredBy")
  payrollEntries    PayrollEntry[]
  payslips          Payslip[]
  onboardingDocuments EmployeeOnboardingDocument[]
  payGroupMembers   PayGroupMember[]
  policyAcks        PolicyAcknowledgement[]
  attendanceRegularizations AttendanceRegularization[]
  rosterAssignments RosterAssignment[]
  compOffCredits    CompOffCredit[]
  reimbursementClaims ReimbursementClaim[]
  employeeLoans     EmployeeLoan[]
  payrollAdjustments PayrollAdjustment[]
  taxDeclarations   TaxDeclaration[]
  trainingEnrollments TrainingEnrollment[]
  assetAssignments  AssetAssignment[]
  supportTickets    SupportTicket[]
  recognitionsGiven Recognition[] @relation("RecognitionFrom")
  recognitionsReceived Recognition[] @relation("RecognitionTo")

  @@unique([tenantId, employeeCode])
  @@index([tenantId, managerId])
  @@unique([tenantId, email])
  @@index([tenantId, id])
}

model EmployeeOnboardingDocument {
  id               String                        @id @default(uuid())
  tenantId         String
  tenant           Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId       String
  employee         Employee                      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  documentType     EmployeeOnboardingDocumentType
  originalFilename String
  storedFilename   String
  mimeType         String
  sizeBytes        Int
  expiresAt        DateTime?
  createdAt        DateTime                      @default(now())

  @@index([tenantId, employeeId])
  @@index([employeeId])
}

// ─── Salary ────────────────────────────────────────

model SalaryComponent {
  id          String              @id @default(uuid())
  tenantId    String
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  type        SalaryComponentType
  isTaxable   Boolean             @default(true)
  metadata    Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  structureRows SalaryStructureComponent[]

  @@index([tenantId, id])
}

model SalaryStructure {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  components  SalaryStructureComponent[]
  assignments SalaryAssignment[]

  @@index([tenantId, id])
}

model SalaryStructureComponent {
  id            String          @id @default(uuid())
  structureId   String
  structure     SalaryStructure @relation(fields: [structureId], references: [id], onDelete: Cascade)
  componentId   String
  component     SalaryComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  amount        Decimal?        @db.Decimal(14, 2)
  percentOfBasic Decimal?       @db.Decimal(7, 4)
  sortOrder     Int             @default(0)

  @@index([structureId])
}

model SalaryAssignment {
  id          String          @id @default(uuid())
  employeeId  String
  employee    Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  structureId String
  structure   SalaryStructure @relation(fields: [structureId], references: [id], onDelete: Cascade)
  effectiveFrom DateTime
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  version     Int             @default(0)

  revisions   SalaryRevision[]

  @@index([employeeId])
}

model SalaryRevision {
  id           String           @id @default(uuid())
  assignmentId String
  assignment   SalaryAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  payload      Json
  effectiveOn  DateTime
  reason       String?
  createdAt    DateTime         @default(now())
}

// ─── Attendance & leave ────────────────────────────

model AttendanceRecord {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  status     String
  /// First biometric / gate punch (arrival)
  checkIn    DateTime?
  /// Last biometric / gate punch (departure)
  checkOut   DateTime?
  remarks    String?
  /// manual | biometric | import | system
  source     String   @default("manual")
  /// Optional structured sessions / integration payload (shift windows, splits, device metadata)
  detail     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([tenantId, date])
}

model LeaveType {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String
  name        String
  daysPerYear      Int
  carryForwardMax  Int?
  accrualPolicy    Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  balances    LeaveBalance[]
  requests    LeaveRequest[]

  @@unique([tenantId, code])
  @@index([tenantId, id])
}

model LeaveBalance {
  id           String    @id @default(uuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId  String
  leaveType    LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  balanceDays  Decimal   @db.Decimal(6, 2)
  year         Int
  updatedAt    DateTime  @updatedAt

  @@unique([employeeId, leaveTypeId, year])
}

model LeaveRequest {
  id          String             @id @default(uuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId String
  leaveType   LeaveType          @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  startDate   DateTime           @db.Date
  endDate     DateTime           @db.Date
  workingDays Decimal            @db.Decimal(6, 2)
  reason      String?
  status      LeaveRequestStatus @default(PENDING)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([tenantId, status])
}

model Task {
  id           String       @id @default(uuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assigneeId   String
  assignee     Employee     @relation(fields: [assigneeId], references: [id], onDelete: Cascade)
  assignedById String
  assignedBy   User         @relation("TaskAssignedBy", fields: [assignedById], references: [id], onDelete: Cascade)
  title        String
  description  String?
  status       TaskStatus   @default(PENDING)
  priority     TaskPriority @default(MEDIUM)
  dueDate      DateTime?    @db.Date
  acceptedAt   DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, assigneeId])
}

model VisitorRecord {
  id                    String    @id @default(uuid())
  tenantId              String
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                  String
  phone                 String
  purpose               String
  visitToName           String
  visitToEmployeeId     String?
  visitToEmployee       Employee? @relation("VisitorHost", fields: [visitToEmployeeId], references: [id], onDelete: SetNull)
  visitedAt             DateTime
  photoStoredFilename   String?
  photoMimeType         String?
  photoSizeBytes        Int?
  photoOriginalFilename String?
  registeredByEmployeeId String
  registeredBy          Employee  @relation("VisitorRegisteredBy", fields: [registeredByEmployeeId], references: [id], onDelete: Cascade)
  checkedOutAt          DateTime?
  hostNotifiedAt        DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([tenantId, visitedAt])
  @@index([tenantId, visitToEmployeeId])
}

model PayGroup {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  filterJson  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  members     PayGroupMember[]
  payrollRuns PayrollRun[]

  @@index([tenantId])
}

model PayGroupMember {
  id         String   @id @default(uuid())
  payGroupId String
  payGroup   PayGroup @relation(fields: [payGroupId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([payGroupId, employeeId])
}

model LegalEntity {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  pan       String?
  gstin     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]

  @@index([tenantId])
}

model PolicyDocument {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  body        String
  version     String   @default("1.0")
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  acknowledgements PolicyAcknowledgement[]

  @@index([tenantId])
}

model PolicyAcknowledgement {
  id         String         @id @default(uuid())
  policyId   String
  policy     PolicyDocument @relation(fields: [policyId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  acknowledgedAt DateTime @default(now())

  @@unique([policyId, employeeId])
}

model Shift {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rosters   RosterAssignment[]

  @@index([tenantId])
}

model RosterAssignment {
  id         String   @id @default(uuid())
  shiftId    String
  shift      Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date

  @@unique([employeeId, date])
  @@index([shiftId, date])
}

model AttendanceRegularization {
  id          String   @id @default(uuid())
  tenantId    String
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  requestedIn DateTime?
  requestedOut DateTime?
  reason      String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
}

model CompOffCredit {
  id         String   @id @default(uuid())
  tenantId   String
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  creditDays Decimal  @db.Decimal(6, 2)
  reason     String?
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())

  @@index([tenantId, employeeId])
}

model ReimbursementClaim {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  category    String
  amount      Decimal  @db.Decimal(14, 2)
  description String?
  status      String   @default("PENDING")
  receiptRef  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
}

model EmployeeLoan {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  principal     Decimal  @db.Decimal(14, 2)
  balance       Decimal  @db.Decimal(14, 2)
  emiAmount     Decimal  @db.Decimal(14, 2)
  startDate     DateTime @db.Date
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, employeeId])
}

model PayrollAdjustment {
  id           String     @id @default(uuid())
  payrollRunId String?
  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  label        String
  amount       Decimal    @db.Decimal(14, 2)
  type         String
  createdAt    DateTime   @default(now())

  @@index([employeeId])
}

model TaxDeclaration {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  year       Int
  regime     String   @default("NEW")
  payload    Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([employeeId, year])
}

model Announcement {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title     String
  body      String
  pinned    Boolean  @default(false)
  authorId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, createdAt])
}

model SupportTicket {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  subject     String
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  comments    SupportTicketComment[]

  @@index([tenantId, status])
}

model SupportTicketComment {
  id        String        @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  body      String
  createdAt DateTime      @default(now())

  @@index([ticketId])
}

model Recognition {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromId     String
  from       Employee @relation("RecognitionFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toId       String
  to         Employee @relation("RecognitionTo", fields: [toId], references: [id], onDelete: Cascade)
  message    String
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
}

model TrainingCourse {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  description String?
  createdAt   DateTime @default(now())

  enrollments TrainingEnrollment[]

  @@index([tenantId])
}

model TrainingEnrollment {
  id         String         @id @default(uuid())
  courseId   String
  course     TrainingCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  status     String         @default("ENROLLED")
  completedAt DateTime?

  @@unique([courseId, employeeId])
}

model Asset {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  serialNo    String?
  category    String?
  createdAt   DateTime @default(now())

  assignments AssetAssignment[]

  @@index([tenantId])
}

model AssetAssignment {
  id         String    @id @default(uuid())
  assetId    String
  asset      Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  assignedAt DateTime  @default(now())
  returnedAt DateTime?

  @@index([assetId])
}

// ─── Payroll ────────────────────────────────────────

model PayrollRun {
  id                   String            @id @default(uuid())
  tenantId             String
  tenant               Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  periodYear           Int
  periodMonth          Int
  status               PayrollRunStatus  @default(DRAFT)
  initiatedById        String?
  /// Employees manually or auto-excluded from this run (not paid this cycle)
  excludedEmployeeIds  String[]          @default([])
  ackWarnings          Boolean           @default(false)
  ackWarningsReason    String?
  /// Default payment rail for salary file (NEFT is typical for payroll)
  disbursementPaymentMethod SalaryPaymentMethod @default(NEFT)
  payGroupId           String?
  payGroup             PayGroup?         @relation(fields: [payGroupId], references: [id], onDelete: SetNull)
  includeReimbursements Boolean          @default(false)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  version              Int               @default(0)

  entries              PayrollEntry[]
  payslips             Payslip[]

  @@unique([tenantId, periodYear, periodMonth])
  @@index([tenantId, id])
}

model PayrollEntry {
  id           String     @id @default(uuid())
  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  gross        Decimal    @db.Decimal(14, 2)
  deductions   Decimal    @db.Decimal(14, 2)
  net          Decimal    @db.Decimal(14, 2)
  breakdown    Json?
  createdAt    DateTime   @default(now())

  @@unique([payrollRunId, employeeId])
}

model Payslip {
  id           String     @id @default(uuid())
  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  pdfKey       String?
  createdAt    DateTime   @default(now())

  @@unique([payrollRunId, employeeId])
}

// ─── Audit & notifications ────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String?
  action     String
  entityType String
  entityId   String?
  diff       Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  title     String
  body      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([tenantId, userId])
}

model NotificationPreference {
  id        String  @id @default(uuid())
  userId    String
  eventCode String
  emailOn   Boolean @default(true)

  @@unique([userId, eventCode])
}

// ─── Billing ───────────────────────────────────────

model Subscription {
  id                     String             @id @default(uuid())
  tenantId               String             @unique
  tenant                 Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  razorpayCustomerId     String?
  razorpaySubscriptionId String?
  status                 SubscriptionStatus @default(TRIALING)
  planCode               String?
  trialEndsAt            DateTime?
  currentPeriodEnd       DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  invoices Invoice[]
}

model Invoice {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount         Decimal      @db.Decimal(14, 2)
  currency       String       @default("INR")
  status         String
  pdfUrl         String?
  periodYear     Int?
  periodMonth    Int?
  paidAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([subscriptionId, createdAt])
}

/// SaaS owner ops: subscription revenue vs infra cost per tenant
model TenantBillingOps {
  id                   String              @id @default(uuid())
  tenantId             String              @unique
  tenant               Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  monthlyFeeInr        Decimal             @db.Decimal(14, 2)
  monthlyServerCostInr Decimal             @db.Decimal(14, 2)
  paymentStatus        TenantPaymentStatus @default(UNPAID)
  lastPaidAt           DateTime?
  billingNotes         String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

// ─── Demo-mode mock providers ──────────────────────────────────────────────
//
// These tables back the @sangam/demo mock providers. They exist in the schema
// regardless of DEMO_MODE so production schema stays consistent, but rows are
// only written when DEMO_MODE=true.

/// Replaces SendGrid in demo mode. Every "send" inserts a row here; the
/// /platform/inbox admin page renders the queue so testers can read OTPs,
/// password-reset tokens, invites etc.
model MockEmail {
  id        String   @id @default(uuid())
  tenantId  String?
  toEmail   String
  fromEmail String   @default("no-reply@sangam.local")
  subject   String
  body      String
  /// Used by the inbox UI to deep-link to the source action (e.g. "reset-password", "verify-email").
  category  String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([toEmail, createdAt])
}

/// Replaces S3 / Vercel Blob in demo mode. Stores file metadata only — the
/// download Route Handler serves a sample PDF from apps/web/public/samples/.
model MockUpload {
  id         String   @id @default(uuid())
  tenantId   String?
  /// Where this upload would have been bucketed in real storage (e.g. "tenant-legal-docs").
  kind       String
  /// Logical reference (e.g. employeeId or document slug).
  ownerRef   String?
  fileName   String
  mimeType   String
  sizeBytes  Int
  /// Always "mock" when DEMO_MODE=true; later "s3" or "blob".
  storage    String   @default("mock")
  /// In demo mode points to /samples/sample-document.pdf etc.
  url        String
  /// Base64 payload for demo-mode uploads where bytes cannot live on disk.
  dataBase64 String?  @db.Text
  uploadedBy String?
  createdAt  DateTime @default(now())

  @@index([tenantId, kind, createdAt])
}
