# =============================================================================
# Sangam — consolidated env example (Next.js + Prisma + Vercel + Neon)
# =============================================================================
# Copy to .env.local for local development. On Vercel, set these in the
# project's Environment Variables UI.
# =============================================================================

NODE_ENV=development

# -------- Database (Neon Postgres) --------
# Pooled connection (used at runtime by Prisma Client)
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/sangam?sslmode=require&pgbouncer=true&connection_limit=1
# Direct connection (used by `prisma migrate` and `prisma db push`; do NOT use at runtime)
DIRECT_DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/sangam?sslmode=require

# -------- Frontend public --------
# Leave empty in production to use same-origin /v1/* calls. Set for local dev if
# pointing at a separate API host.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_DATA_SOURCE=api

# -------- Auth (JWT) --------
JWT_SECRET=change-me-min-32-chars-for-development-only
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-dev
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# -------- Demo mode --------
# When true, third-party integrations (Razorpay, SendGrid, S3, pdfkit,
# biometric) are replaced by mock providers from @sangam/demo. Flip to false
# and provide real keys to wire each integration for real.
DEMO_MODE=true

# Artificial latency in ms applied to API responses (for demo UX testing)
DEMO_LATENCY_MS=0

# Log OTPs / skip email verification gate (dev only)
DEV_AUTH_VERBOSE=true

# -------- Optional integrations (validated at startup; placeholders ok in demo) --------
AWS_S3_BUCKET=dev-placeholder
SENDGRID_API_KEY=SG.placeholder

# Razorpay — https://dashboard.razorpay.com (placeholders enable mock subscribe in dev)
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=placeholder
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_GROWTH=
BILLING_TRIAL_DAYS=14

# Default password suffix appended to company code for employees
EMPLOYEE_DEFAULT_PASSWORD_KEYWORD=Vetan

# Local storage dirs (ignored when DEMO_MODE=true or Vercel deploy)
LEGAL_DOCUMENTS_DIR=uploads/tenant-legal-docs
EMPLOYEE_DOCUMENTS_DIR=uploads/employee-docs

# -------- Same-origin CORS (legacy) --------
# Leave unset once cutover to single Next deployment completes.
FRONTEND_URL=http://localhost:3000
# CORS_EXTRA_ORIGINS=
